# OpenExec Environment Variables
# Copy this file to .env and configure as needed

# Note: AI configuration is now in settings.json
# See settings.json for base_url, model, and other AI settings

# Agent settings (override config/openexec.yaml)
AGENT_ANALYSIS_DEPTH=medium
AGENTS_ENABLED=ceo,cfo,cto,cmo

# Simulation settings
SIMULATION_MAX_INTERACTIONS=10
CONFIDENCE_THRESHOLD=0.6

# Output settings
OUTPUT_FORMAT=markdown
