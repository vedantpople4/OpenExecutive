# Review Prompt Template
REVIEW_PROMPT_TEMPLATE = """## Cross-Functional Review
You are the {{ agent_name.upper() }}. Review the following reports from other executives:
Be direct. Flag conflicts. Do not soften your assessment.

{% for other_agent, report in other_reports.items() %}
{% if other_agent != agent_name %}
### {{ other_agent.upper() }} Report
**Title:** {{ report.get('title', 'N/A') }}
**Verdict:** {{ report.get(other_agent + '_verdict', report.get('summary', 'N/A')) }}
**Summary:** {{ report.get('summary', 'N/A') }}
{% if report.get('key_findings') %}
**Key Findings:**
{% for f in report['key_findings'] %}
- {{ f }}
{% endfor %}
{% endif %}
{% if report.get('recommendations') %}
**Recommendations:**
{% for rec in report['recommendations'] %}
- {{ rec }}
{% endfor %}
{% endif %}
{% if report.get('risks') %}
**Risks:**
{% for r in report['risks'] %}
- {{ r }}
{% endfor %}
{% endif %}
{% endif %}
{% endfor %}

## Your Review
From your lens, answer: (1) Where do you agree? (2) Where do you conflict with their analysis? (3) What must change in their recommendations before you can align? Return as JSON with fields: agreements, conflicts, required_changes."""


